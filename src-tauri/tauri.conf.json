{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Calendar Notifier",
  "mainBinaryName": "calendar-notifier",
  "version": "0.3.0",
  "identifier": "com.calendarnotifier.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Calendar Notifier",
        "width": 800,
        "height": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/julipinto/calendar-notifier/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhERjE5MUY5NkM2OTZENTMKUldSVGJXbHMrWkh4amNIamo3MlNzWVhKdWYxUkZzc1M5WC9CMk8wbzk2Q0x6K3hrT0ovMEFXeTYK"
    }
  }
}
